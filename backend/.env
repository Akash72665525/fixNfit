# Server Configuration
NODE_ENV=development
PORT=5000

# Database — use MongoDB Atlas URI for production
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/fixnfit_ecommerce

# JWT Secret — change to a strong random string in production (min 32 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# Frontend URL — set to your Vercel URL in production (no trailing slash)
# Multiple origins supported (comma-separated): https://app.vercel.app,https://www.yourdomain.com
FRONTEND_URL=http://localhost:3000

# Email Configuration (Gmail with App Password)
# 1. Enable 2FA on Gmail: https://myaccount.google.com/security
# 2. Generate App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# Payment Gateways
# Razorpay (Get from: https://dashboard.razorpay.com/app/keys)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret_key

# Stripe (Get from: https://dashboard.stripe.com/apikeys)
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxx
